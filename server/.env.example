# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=5000
HTTPS_PORT=5443

# ── CORS ──────────────────────────────────────
# In production, use https://
ALLOWED_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=crop_management

# ── JWT ───────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d


